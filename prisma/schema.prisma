generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Loan {
  id            String @id
  name          String
  bank          String
  balance       Float
  totalInterest Float
  monthlyRate   Float
  interestRate  Float
  nextPayment   DateTime
  status        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Insurance {
  id             String @id
  name           String
  provider       String
  monthlyPremium Float
  debitDay       Int
  renewalDate    DateTime?
  coverage       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Income {
  id        String @id
  title     String
  source    String
  amount    Float
  date      DateTime
  recurring Boolean
  entryDay  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id        String @id
  title     String
  category  String
  amount    Float
  date      DateTime
  recurring Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MonthlyBudget {
  id       String @id @default(cuid())
  category String
  planned  Float
  spent    Float
}

model PaymentConfirmation {
  id         String @id
  paidAmount Float
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}
