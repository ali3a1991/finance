generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Loan {
  id            String @id
  ownerId       String?
  name          String
  bank          String
  balance       Float
  totalInterest Float
  monthlyRate   Float
  interestRate  Float
  startDate     DateTime?
  endDate       DateTime?
  nextPayment   DateTime
  status        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Insurance {
  id             String @id
  ownerId        String?
  name           String
  provider       String
  monthlyPremium Float
  debitDay       Int
  startDate      DateTime?
  endDate        DateTime?
  renewalDate    DateTime?
  coverage       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model GeneralContract {
  id            String   @id
  ownerId       String?
  title         String
  provider      String
  category      String
  monthlyAmount Float
  debitDay      Int
  startDate     DateTime
  endDate       DateTime?
  note          String?
  status        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Income {
  id        String @id
  ownerId   String?
  title     String
  source    String
  amount    Float
  date      DateTime
  recurring Boolean
  entryDay  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id        String @id
  ownerId   String?
  title     String
  category  String
  amount    Float
  date      DateTime
  recurring Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Investment {
  id            String   @id
  ownerId       String?
  assetName     String
  symbol        String
  quantity      Float
  purchasePrice Float
  purchaseDate  DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MonthlyBudget {
  id       String @id @default(cuid())
  ownerId  String?
  category String
  planned  Float
  spent    Float
}

model PaymentConfirmation {
  id         String @id
  ownerId    String?
  paidAmount Float
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model AppUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  ownerId      String
  accessLevel  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RegistrationChallenge {
  id                   String   @id @default(cuid())
  username             String
  passwordHash         String
  telegramContact      String
  code                 String
  codeHash             String
  transferSharedUserId String?
  expiresAt            DateTime
  createdAt            DateTime @default(now())
}

model TelegramContact {
  id        String   @id @default(cuid())
  username  String   @unique
  contact   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
